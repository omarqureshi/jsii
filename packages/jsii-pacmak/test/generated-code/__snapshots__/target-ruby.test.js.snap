        Jsii::Object.register_jsii_fqn("jsii-calc.ImplictBaseOfBase", self)

        def initialize(foo:, bar:, goo:)
          
            @foo = foo
            @bar = bar
            @goo = goo
        end

        attr_reader :foo
        attr_reader :bar
        attr_reader :goo

        def self.jsii_properties
          
            {
              
                :foo => "foo",
                :bar => "bar",
                :goo => "goo",
            }
        end

        def to_jsii
          
            result = {}
            result.merge!(super)
            result.merge!({
              
                "foo" => @foo,
                "bar" => @bar,
                "goo" => @goo,
            })
            result.compact
        end
    end

